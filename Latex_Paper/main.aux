\newlabel{fig:trend}{{1}{2}{Comparison of heart rate kinetics (top) and velocity profiles (bottom) during Trial 3. The upper-arm sensor (blue) captures dynamic peaks, whereas the wrist sensor (orange) exhibits latency and data omissions}{figure.caption.2}{}}
\def\@LN@column{2}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Statistical agreement between upper-arm and wrist sensors for Trial 3. The scatterplot (a) reveals a moderate correlation with notable spread. The Bland-Altman plot (b) shows a small mean bias ($-1.9$\,bpm) but wide 95\% limits of agreement ($+14.6$ to $-18.5$\,bpm), with underestimation by the wrist sensor increasingly visible at higher heart rates. Trial~3 is close to the cross-run \emph  {median} agreement (Figure~\ref {fig:hragreement}), but not to the cross-run \emph  {mean}, which is pulled down by Run~2.}}{2}{figure.caption.4}\protected@file@percent }
\newlabel{fig:agreement}{{2}{2}{Statistical agreement between upper-arm and wrist sensors for Trial 3. The scatterplot (a) reveals a moderate correlation with notable spread. The Bland-Altman plot (b) shows a small mean bias ($-1.9$\,bpm) but wide 95\% limits of agreement ($+14.6$ to $-18.5$\,bpm), with underestimation by the wrist sensor increasingly visible at higher heart rates. Trial~3 is close to the cross-run \emph {median} agreement (Figure~\ref {fig:hragreement}), but not to the cross-run \emph {mean}, which is pulled down by Run~2}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Sample Size \& Power Validation}{2}{subsection.4.1}\protected@file@percent }
