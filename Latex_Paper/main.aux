\newlabel{fig:power}{{5}{5}{Geospatial tracking accuracy for Trial 3 (a) and statistical power validation (b). $N=6$ achieves 53.2\% power; $n\approx 13$ trials would be required for the conventional 80\% target}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces GPS offset between upper-arm and wrist tracks across all $N=6$ runs. The cross-run mean (4.56\,m, dashed line) is the representative figure reported in the Abstract; per-run means range from 2.1 to 8.3\,m, with individual maxima up to 30.5\,m (Run 2).}}{5}{figure.caption.8}\protected@file@percent }
\newlabel{fig:gpsoffset}{{6}{5}{GPS offset between upper-arm and wrist tracks across all $N=6$ runs. The cross-run mean (4.56\,m, dashed line) is the representative figure reported in the Abstract; per-run means range from 2.1 to 8.3\,m, with individual maxima up to 30.5\,m (Run 2)}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {paragraph}{External validity.}{5}{section*.14}\protected@file@percent }
\def\@LN@column{2}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Relative GPS track-length error (upper arm as reference) across all $N=6$ runs. The cross-run mean (1.5\%, dashed line) is again driven up by Run~2 (4.2\%), consistent with the GPS-offset and HR-agreement outliers observed for the same run (see Section~5).}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{fig:distanceerror}{{7}{5}{Relative GPS track-length error (upper arm as reference) across all $N=6$ runs. The cross-run mean (1.5\%, dashed line) is again driven up by Run~2 (4.2\%), consistent with the GPS-offset and HR-agreement outliers observed for the same run (see Section~5)}{figure.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Cross-run correlations ($N=6$ runs treated as observations) between degradation metrics. Distance error and HR lag both correlate significantly with weaker HR agreement, supporting a shared underlying cause; speed agreement correlates with none of them, suggesting it fails independently.}}{5}{table.caption.10}\protected@file@percent }
\newlabel{tab:correlations}{{2}{5}{Cross-run correlations ($N=6$ runs treated as observations) between degradation metrics. Distance error and HR lag both correlate significantly with weaker HR agreement, supporting a shared underlying cause; speed agreement correlates with none of them, suggesting it fails independently}{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Visual comparison of the optical sensor arrays. (a) The over-4-year-old smartwatch shows a distinct round, milky-white discoloration and scratching directly over the PPG window. (b) The newer upper-arm array shows an intact, clear optical barrier.}}{5}{figure.caption.12}\protected@file@percent }
\newlabel{fig:devices}{{8}{5}{Visual comparison of the optical sensor arrays. (a) The over-4-year-old smartwatch shows a distinct round, milky-white discoloration and scratching directly over the PPG window. (b) The newer upper-arm array shows an intact, clear optical barrier}{figure.caption.12}{}}
