\newlabel{tab:results}{{1}{3}{Comprehensive sensor and track evaluation ($N=6$ synchronized runs)}{table.caption.3}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces HR agreement (Pearson $r$, top; MAE, bottom) between upper-arm and wrist sensors across all $N=6$ runs. Cross-run mean $r=0.60$ (median $0.66$) and mean MAE $=8.9$\,bpm. The single-trial example in Figure~\ref {fig:agreement} ($r=0.65$) closely matches the cross-run \emph  {median}, but the \emph  {mean} is pulled substantially lower by Run~2 ($r=0.03$, MAE $=22.1$\,bpm), illustrating why a single representative trial can understate the overall variance in device agreement (see Section~5).}}{3}{figure.caption.5}\protected@file@percent }
\newlabel{fig:hragreement}{{3}{3}{HR agreement (Pearson $r$, top; MAE, bottom) between upper-arm and wrist sensors across all $N=6$ runs. Cross-run mean $r=0.60$ (median $0.66$) and mean MAE $=8.9$\,bpm. The single-trial example in Figure~\ref {fig:agreement} ($r=0.65$) closely matches the cross-run \emph {median}, but the \emph {mean} is pulled substantially lower by Run~2 ($r=0.03$, MAE $=22.1$\,bpm), illustrating why a single representative trial can understate the overall variance in device agreement (see Section~5)}{figure.caption.5}{}}
\newlabel{eq:power}{{1}{3}{Sample Size \& Power Validation}{equation.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5}Discussion \& Limitations}{3}{section.5}\protected@file@percent }
\def\@LN@column{2}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Bland-Altman plots for all $N=6$ runs individually. Run~1, 3, 5, and 6 show the expected pattern of tight agreement with modest bias; Run~4 shows a persistent positive bias; Run~2 shows the characteristic three-cluster split described in Section~5, a direct visual signature of the cadence-lock event rather than random measurement noise.}}{4}{figure.caption.6}\protected@file@percent }
\newlabel{fig:blandaltmangrid}{{4}{4}{Bland-Altman plots for all $N=6$ runs individually. Run~1, 3, 5, and 6 show the expected pattern of tight agreement with modest bias; Run~4 shows a persistent positive bias; Run~2 shows the characteristic three-cluster split described in Section~5, a direct visual signature of the cadence-lock event rather than random measurement noise}{figure.caption.6}{}}
