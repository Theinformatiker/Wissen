\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Comparison of heart rate kinetics (top) and velocity profiles (bottom) during Trial 3. The upper-arm sensor (blue) captures dynamic peaks, whereas the wrist sensor (orange) exhibits latency and data omissions.}}{2}{figure.caption.2}\protected@file@percent }
